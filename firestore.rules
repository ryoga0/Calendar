rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isUserScopedLock(lockId) {
      return signedIn() && lockId.matches('^' + request.auth.uid + '_.*$');
    }

    match /departments/{departmentId} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{userId} {
      allow read, create, update: if isOwner(userId);
      allow delete: if false;

      match /appointments/{appointmentId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && request.resource.data.user_id == userId;
        allow delete: if isOwner(userId);
      }
    }

    match /user_department_locks/{lockId} {
      allow read, delete: if isUserScopedLock(lockId);
      allow create, update: if isUserScopedLock(lockId) && request.resource.data.user_id == request.auth.uid;
    }

    match /user_slot_locks/{lockId} {
      allow read, delete: if isUserScopedLock(lockId);
      allow create, update: if isUserScopedLock(lockId) && request.resource.data.user_id == request.auth.uid;
    }

    match /department_slot_locks/{lockId} {
      allow read: if true;
      allow create, update: if signedIn() && request.resource.data.user_id == request.auth.uid;
      allow delete: if signedIn() && resource.data.user_id == request.auth.uid;
    }
  }
}
